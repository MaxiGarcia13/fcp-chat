---
import { EntryForm } from '@/components/entry-form';
import Layout from '@/layouts/layout.astro';
---

<Layout class="justify-center">
  <section class="mx-auto w-full max-w-xl space-y-4">
    <h1 class="text-2xl font-bold">Asistente FCP Chat</h1>
    <p class="text-sm opacity-80">
      Elige genero y grupo para entrar para poder elegir el equipo.
    </p>

    <div class="min-w-0 overflow-hidden rounded-xl border border-cantabria-border/60 bg-cantabria-surface p-5 shadow-sm sm:p-6">
      <EntryForm client:only="react" />
    </div>
  </section>
</Layout>

---
import { ClientRouter } from 'astro:transitions';
import Breadcrumbs from '@/components/breadcrumbs.astro';
import {
  APP_NAME,
  APP_VERSION,
  AUTHOR_NAME,
  BASE_IMAGE_URL,
  LINKEDIN_URL,
  REPOSITORY_URL,
} from '@/constants/global';
import { cn } from '@/utils/classes';
import '@/styles/global.css';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const pathname = Astro.url.pathname;
const isHomePage = pathname === '/';

const siteTitle = 'Chat con IA para la Liga Cantabra de Padel';
const description =
  `Esta app de chat con IA te ayuda a encontrar la tabla de posiciones, conocer los proximos partidos, comparar equipos y sugerir posibles alineaciones para la semana en la Liga Cantabra de Padel.`.trim();

const canonicalUrl = Astro.url.href;
const ogImageUrl = new URL(BASE_IMAGE_URL, Astro.url).toString();
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="canonical" href={canonicalUrl} />

    <title>{siteTitle}</title>

    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta name="author" content={AUTHOR_NAME} />
    <meta name="application-name" content={APP_NAME} />
    <meta name="theme-color" content="#0f172a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={APP_NAME} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={APP_NAME} />
    <meta property="og:locale" content="es_ES" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={siteTitle} />
    <meta property="twitter:description" content={description} />

    <meta property="linkedin:card" content="summary_large_image" />
    <meta property="linkedin:url" content={canonicalUrl} />
    <meta property="linkedin:title" content={siteTitle} />
    <meta property="linkedin:description" content={description} />
    <meta property="linkedin:image" content={ogImageUrl} />

    <meta property="twitter:image" content={ogImageUrl} />

    <ClientRouter />
  </head>
  <body class="min-h-screen bg-cantabria-bg text-cantabria-text antialiased">
    <main
      class={cn(
        'mx-auto max-w-4xl px-4 py-8 sm:py-10 min-h-screen flex flex-col',
        className,
      )}
    >
      {!isHomePage && <Breadcrumbs pathname={pathname} />}
      <slot />
      <footer
        class="border-t border-cantabria-border/40 pt-6 text-center text-xs text-cantabria-muted"
      >
        <p>
          v{APP_VERSION}
          <span class="mx-1.5 opacity-50" aria-hidden="true">·</span>
          <a
            href={REPOSITORY_URL}
            class="text-cantabria-link underline-offset-2 hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            Repositorio
          </a>
          <span class="mx-1.5 opacity-50" aria-hidden="true">·</span>
          Creado por{' '}
          <a
            href={LINKEDIN_URL}
            class="text-cantabria-link underline-offset-2 hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            {AUTHOR_NAME}
          </a>
        </p>
      </footer>
    </main>
  </body>
</html>

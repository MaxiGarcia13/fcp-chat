---
import { ClientRouter } from 'astro:transitions';
import Breadcrumbs from '@/components/breadcrumbs.astro';
import { cn } from '@/utils/classes';
import pkg from '../../package.json';
import '@/styles/global.css';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const repoUrl =
  typeof pkg.repository === 'object' && pkg.repository?.url
    ? pkg.repository.url.replace(/^git\+/, '').replace(/\.git$/, '')
    : (pkg.homepage?.split('#')[0] ?? '#');

const authorLinkedInUrl = 'https://www.linkedin.com/in/maximilianogarcia13';

const pathname = Astro.url.pathname;
const isHomePage = pathname === '/';

const description = `
This project provides an AI-powered chat that can help you:

- Find team standings and rankings
- Get info about next week's matches
- Compare teams and highlight key differences
- Suggest weekly lineups / possible pairings for upcoming matches
- Answer general league/competition questions
`.trim();
---

<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="canonical" href={Astro.url.href} />

    <title>Chat assistant for the Liga Cantabra de Padel.</title>

    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta
      property="og:title"
      content="Chat assistant for the Liga Cantabra de Padel."
    />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/favicon.png', Astro.url)} />
    <meta property="og:locale" content="es_ES" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta
      property="twitter:title"
      content="Chat assistant for the Liga Cantabra de Padel."
    />
    <meta property="twitter:description" content={description} />

    <meta name="linkedin:card" content="summary_large_image" />
    <meta name="linkedin:url" content={Astro.url.href} />
    <meta
      name="linkedin:title"
      content="Chat assistant for the Liga Cantabra de Padel."
    />
    <meta name="linkedin:description" content={description} />
    <meta name="linkedin:image" content={new URL('/favicon.png', Astro.url)} />

    <meta
      property="twitter:image"
      content={new URL('/favicon.png', Astro.url)}
    />

    <ClientRouter />
  </head>
  <body class="min-h-screen bg-cantabria-bg text-cantabria-text antialiased">
    <main
      class={cn(
        'mx-auto max-w-4xl px-4 py-8 sm:py-10 min-h-screen flex flex-col',
        className,
      )}
    >
      {!isHomePage && <Breadcrumbs pathname={pathname} />}
      <slot />
      <footer
        class="border-t border-cantabria-border/40 pt-6 text-center text-xs text-cantabria-muted"
      >
        <p>
          v{pkg.version}
          <span class="mx-1.5 opacity-50" aria-hidden="true">·</span>
          <a
            href={repoUrl}
            class="text-cantabria-link underline-offset-2 hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            Repositorio
          </a>
          <span class="mx-1.5 opacity-50" aria-hidden="true">·</span>
          Creado por{' '}
          <a
            href={authorLinkedInUrl}
            class="text-cantabria-link underline-offset-2 hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            {pkg.author}
          </a>
        </p>
      </footer>
    </main>
  </body>
</html>
